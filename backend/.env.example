# Copia este archivo a .env en tu PC (no subas .env a Git).
# En Render/Vercel: agrega cada variable en la sección de Environment Variables.

# Base de datos — CockroachDB Serverless
COCKROACH_URL=postgresql://user:password@host.cockroachlabs.cloud:26257/defaultdb?sslmode=require

# CORS — por defecto CERRADO (CORS_OPEN ausente o "0").
# En producción: lista los orígenes reales separados por coma.
# Para pruebas locales temporales: CORS_OPEN=1 (NO dejar en producción).
FRONTEND_URLS=https://alejoarango8a.github.io
# CORS_OPEN=1  ← descomenta SOLO para debugging puntual

# Colombia (opcional): cuenta b1 CUIF para ranking patrimonio en bootstrap con ?country=CO
# CO_EQUITY_CUENTA=210000
